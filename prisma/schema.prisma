// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  points         Int       @default(100) // starts at 100, cumulative
  streak         Int       @default(0)
  lastActiveDate DateTime?

  coachMessages CoachMessage[]

  accounts          Account[]
  sessions          Session[]
  sessionsAsUser1   MatchSession[]     @relation("User1")
  sessionsAsUser2   MatchSession[]     @relation("User2")
  pointTransactions PointTransaction[]

  createdAt DateTime @default(now())
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int // positive or negative
  reason    String // "session_complete", "left_early", "non_english", "good_rating"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchSession {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String?
  status    String // "waiting" | "active" | "ended"
  level     String   @default("beginner") // "beginner" | "intermediate" | "advanced"
  topic     String   @default("casual") // "casual" | "business" | "travel" | "interview" | "debate"
  createdAt DateTime @default(now())

  user1 User  @relation("User1", fields: [user1Id], references: [id])
  user2 User? @relation("User2", fields: [user2Id], references: [id])
}
